# ---- Next.js ----
/.next/
/out/
/build

# ---- Dependencies ----
/node_modules

# ---- Environment secrets — never commit real values ----
.env
.env.local
.env.*.local

# ---- Supabase local dev ----
# Config and migrations ARE committed (they're the schema source of truth).
# Only local runtime artifacts are excluded.
supabase/.branches
supabase/.temp

# ---- TypeScript ----
*.tsbuildinfo
next-env.d.ts

# ---- Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Editor / OS ----
.vscode/*
!.vscode/extensions.json
.DS_Store
Thumbs.db

# ---- Vercel ----
.vercel